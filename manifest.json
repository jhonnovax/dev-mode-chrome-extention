{
  "manifest_version": 3,
  "name": "Dev Mode",
  "version": "1.0.0",
  "description": "Toggle DEV mode cookies and proxy settings",
  "permissions": [
    "cookies",
    "scripting",
    "proxy",
    "storage",
    "declarativeNetRequest",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Dev Mode",
    "default_popup": "popup.html"
  }
}
