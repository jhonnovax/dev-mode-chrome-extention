{
  "manifest_version": 3,
  "name": "Dev Mode",
  "version": "1.0.0",
  "description": "Toggle DEV mode cookies and proxy settings",
  "permissions": [
    "cookies",
    "scripting",
    "proxy",
    "declarativeNetRequest",
    "tabs",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Dev Mode",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
